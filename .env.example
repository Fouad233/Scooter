# Supabase
# URL et clé "anon" : visibles dans le navigateur, à récupérer dans Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé "service role" : donne tous les droits, UNIQUEMENT utilisée côté serveur, jamais exposée au client
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp (format international sans le +, ex: 212600000000)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# URL du site en production (pour le SEO : sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Mot de passe pour accéder à l'espace admin (/admin) : choisis un mot de passe fort
ADMIN_PASSWORD=

# Resend (envoi automatique de l'email de confirmation au client)
# Clé API : créer un compte gratuit sur resend.com > API Keys
RESEND_API_KEY=
# Adresse d'expédition. Tant que ton domaine n'est pas vérifié sur Resend,
# laisse onboarding@resend.dev (fonctionne pour tester).
RESEND_FROM_EMAIL=onboarding@resend.dev

