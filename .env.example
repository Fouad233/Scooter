# Supabase
# URL et clé "anon" : visibles dans le navigateur, à récupérer dans Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé "service role" : donne tous les droits, UNIQUEMENT utilisée côté serveur, jamais exposée au client
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp (format international sans le +, ex: 212600000000)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# URL du site en production (pour le SEO : sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
