# Supabase
# URL et clé "anon" : visibles dans le navigateur, à récupérer dans Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé "service role" : donne tous les droits, UNIQUEMENT utilisée côté serveur, jamais exposée au client
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp (format international sans le +, ex: 212600000000)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# URL du site en production (pour le SEO : sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Mot de passe pour accéder à l'espace admin (/admin) : choisis un mot de passe fort
ADMIN_PASSWORD=
# Clé secrète distincte utilisée pour signer les cookies de session admin.
# Génère une valeur aléatoire : openssl rand -hex 32
# Si vide, repli sur ADMIN_PASSWORD (moins sécurisé).
ADMIN_SESSION_SECRET=

# Gmail (envoi automatique de l'email de confirmation au client)
# 1. Active la validation en 2 étapes sur le compte Gmail à utiliser
# 2. Crée un "mot de passe d'application" : myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=


